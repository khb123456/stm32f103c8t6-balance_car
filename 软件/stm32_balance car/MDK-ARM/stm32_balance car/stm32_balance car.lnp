--library_type=microlib --strict --scatter "stm32_balance car\stm32_balance car.sct"
--summary_stderr --info summarysizes --map --load_addr_map_info --xref --callgraph --symbols
--info sizes --info totals --info unused --info veneers
--list "stm32_balance car.map" -o "stm32_balance car\stm32_balance car.axf"